if ! command -v gitleaks >/dev/null 2>&1; then
	echo "Warning: gitleaks is not installed; skipping the pre-commit secret scan."
	echo "Install it with: brew install gitleaks"
	echo "Other install options: https://github.com/gitleaks/gitleaks#installing"
else
	gitleaks git --pre-commit --redact --staged --verbose || exit 1
fi

if command -v node >/dev/null 2>&1; then
	cd apps/vscode && lint-staged
else
	echo "Warning: node is not available in the Git hook PATH; skipping lint-staged."
	echo "On NixOS, run git from a shell that provides node/bun, or add them to your dev shell/profile."
fi

